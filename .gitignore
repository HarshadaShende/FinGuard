# =====================================================
# FinGuard - Git Ignore
# =====================================================

# -----------------------------------------------------
# Node.js Dependencies
# -----------------------------------------------------

**/node_modules/

# -----------------------------------------------------
# Environment Variables
# -----------------------------------------------------

**/.env
**/.env.*

# Keep sample environment files
!.env.example

# -----------------------------------------------------
# Databases
# -----------------------------------------------------

*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------
# Logs
# -----------------------------------------------------

*.log
logs/

# -----------------------------------------------------
# Test Reports
# -----------------------------------------------------

coverage/
reports/
test-results/
playwright-report/

# -----------------------------------------------------
# JMeter
# -----------------------------------------------------

*.jtl

# -----------------------------------------------------
# Build Output
# -----------------------------------------------------

dist/
build/
out/

# -----------------------------------------------------
# IDE
# -----------------------------------------------------

.vscode/
.idea/

# -----------------------------------------------------
# Operating System
# -----------------------------------------------------

.DS_Store
Thumbs.db

# -----------------------------------------------------
# Temporary Files
# -----------------------------------------------------

*.tmp
*.temp